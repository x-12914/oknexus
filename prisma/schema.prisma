// Prisma schema for the CryptX exchange.
// Provider is Postgres for production; a docker-compose is included for local dev.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth (NextAuth / Auth.js v5) ----------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  kycStatus     KycStatus @default(NONE)
  kycLegalName  String?
  kycCountry    String?
  kycIdNumber   String?
  kycReviewedAt DateTime?
  twoFAEnabled  Boolean   @default(false)
  twoFASecret   String? // encrypted TOTP secret (AES-256-GCM)
  tokenVersion  Int       @default(0) // bump to invalidate all existing sessions ("sign out everywhere")
  suspended     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  wallets  Wallet[]
  orders   Order[]
  trades   Trade[]

  ledgerEntries LedgerEntry[]
  swaps         SwapTx[]
  ramps         RampTx[]
  otcTrades     OtcTrade[]
  p2pOrders     P2POrder[]
  p2pAds        P2PAd[]
  loginEvents   LoginEvent[]

  depositAddresses DepositAddress[]
  deposits         Deposit[]
  withdrawals      Withdrawal[]
}

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Wallets ----------

model Asset {
  symbol   String  @id
  name     String
  decimals Int     @default(8)
  isFiat   Boolean @default(false)
  network  String?
  contract String?
  logoUrl  String?

  wallets      Wallet[]
  baseMarkets  Market[] @relation("BaseAsset")
  quoteMarkets Market[] @relation("QuoteAsset")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  balance   Decimal  @default(0) @db.Decimal(30, 10)
  locked    Decimal  @default(0) @db.Decimal(30, 10)
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [symbol], references: [symbol])

  @@unique([userId, symbol])
}

// ---------- Trading ----------

model Market {
  id           String  @id @default(cuid())
  symbol       String  @unique
  baseSymbol   String
  quoteSymbol  String
  minOrderSize Decimal @default(0) @db.Decimal(30, 10)
  tickSize     Decimal @default(0.01) @db.Decimal(30, 10)
  stepSize     Decimal @default(0.00000001) @db.Decimal(30, 10)
  makerFee     Decimal @default(0.001) @db.Decimal(10, 6)
  takerFee     Decimal @default(0.002) @db.Decimal(10, 6)
  isActive     Boolean @default(true)

  base   Asset   @relation("BaseAsset", fields: [baseSymbol], references: [symbol])
  quote  Asset   @relation("QuoteAsset", fields: [quoteSymbol], references: [symbol])
  orders Order[]
  trades Trade[]
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
  REJECTED
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  marketId     String
  side         OrderSide
  type         OrderType
  price        Decimal?    @db.Decimal(30, 10)
  quantity     Decimal     @db.Decimal(30, 10)
  filledQty    Decimal     @default(0) @db.Decimal(30, 10)
  avgFillPrice Decimal?    @db.Decimal(30, 10)
  status       OrderStatus @default(OPEN)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  market Market  @relation(fields: [marketId], references: [id])
  trades Trade[]

  @@index([marketId, status])
  @@index([userId, createdAt])
}

model Trade {
  id        String    @id @default(cuid())
  marketId  String
  orderId   String
  userId    String
  side      OrderSide
  price     Decimal   @db.Decimal(30, 10)
  quantity  Decimal   @db.Decimal(30, 10)
  fee       Decimal   @default(0) @db.Decimal(30, 10)
  feeSymbol String?
  createdAt DateTime  @default(now())

  market Market @relation(fields: [marketId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
}

// ---------- Ledger (immutable journal over wallet balances) ----------
//
// Every balance movement writes one LedgerEntry per (wallet, account) leg with a
// signed delta and the resulting balance. A single operation (e.g. a swap) writes
// multiple entries sharing a refId. Wallet.balance / Wallet.locked are the running
// totals these entries reconcile to.

enum LedgerAccount {
  AVAILABLE
  LOCKED
}

enum LedgerType {
  SEED
  SWAP
  RAMP
  SPOT
  OTC
  P2P
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT
}

model LedgerEntry {
  id           String        @id @default(cuid())
  userId       String
  symbol       String
  account      LedgerAccount @default(AVAILABLE)
  delta        Decimal       @db.Decimal(30, 10)
  balanceAfter Decimal       @db.Decimal(30, 10)
  type         LedgerType
  refId        String? // groups the legs of one operation
  memo         String?
  createdAt    DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([refId])
}

// ---------- Persisted trade history ----------

model SwapTx {
  id         String   @id @default(cuid())
  userId     String
  fromSymbol String
  toSymbol   String
  fromAmount Decimal  @db.Decimal(30, 10)
  toAmount   Decimal  @db.Decimal(30, 10)
  rate       Decimal  @db.Decimal(30, 10)
  feeSymbol  String?
  feeAmount  Decimal  @default(0) @db.Decimal(30, 10)
  status     String   @default("FILLED")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RampTx {
  id            String    @id @default(cuid())
  userId        String
  side          OrderSide
  fiatCode      String
  cryptoSymbol  String
  fiatAmount    Decimal   @db.Decimal(30, 10)
  totalFiat     Decimal   @db.Decimal(30, 10)
  cryptoAmount  Decimal   @db.Decimal(30, 10)
  paymentMethod String
  status        String    @default("COMPLETED")
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model OtcTrade {
  id             String    @id @default(cuid())
  userId         String
  side           OrderSide
  baseSymbol     String
  settleCurrency String
  baseAmount     Decimal   @db.Decimal(30, 10)
  price          Decimal   @db.Decimal(30, 10)
  totalCost      Decimal   @db.Decimal(30, 10)
  status         String    @default("FILLED")
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------- P2P (persisted escrow trades) ----------

enum P2POrderStatus {
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
  DISPUTED
}

model P2POrder {
  id                   String         @id @default(cuid())
  userId               String
  advertiserId         String? // the ad's advertiser (another real user); null for seeded mock ads
  adId                 String
  asset                String
  fiat                 String
  price                Decimal        @db.Decimal(30, 10)
  assetAmount          Decimal        @db.Decimal(30, 10)
  fiatAmount           Decimal        @db.Decimal(30, 10)
  paymentMethod        String
  status               P2POrderStatus @default(PENDING_PAYMENT)
  takerRole            String // "buyer" | "seller"
  buyerName            String
  sellerName           String
  merchantId           String
  merchant             Json // merchant snapshot for display
  paymentWindowMinutes Int
  escrowLocked         Boolean        @default(false)
  createdAt            DateTime       @default(now())
  expiresAt            DateTime
  completedAt          DateTime?

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages P2PMessage[]

  @@index([userId, createdAt])
}

model P2PMessage {
  id        String   @id @default(cuid())
  orderId   String
  sender    String // "buyer" | "seller" | "system"
  text      String
  createdAt DateTime @default(now())

  order P2POrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model P2PAd {
  id             String    @id @default(cuid())
  advertiserId   String? // null = seeded mock ad
  side           OrderSide // advertiser's action: SELL = they sell crypto; BUY = they buy
  asset          String
  fiat           String
  price          Decimal   @db.Decimal(30, 10)
  available      Decimal   @db.Decimal(30, 10) // asset units still open (locked for SELL ads)
  minLimit       Decimal   @db.Decimal(30, 10) // fiat
  maxLimit       Decimal   @db.Decimal(30, 10) // fiat
  paymentMethods String[]
  terms          String?
  merchantName   String
  merchant       Json // P2PMerchant snapshot for display
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())

  advertiser User? @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@index([side, asset, fiat, active])
  @@index([advertiserId])
}

// ---------- Custody (on-chain deposits & withdrawals) ----------
//
// Per-user deposit addresses are derived from one HD seed (BIP-44). A background
// scanner credits the ledger on confirmed deposits; withdrawals lock funds, sign
// & broadcast from a hot wallet, then settle on confirmation. Testnet today
// (Sepolia/testnet endpoints); flips to mainnet by config.

model ChainState {
  chain            String   @id // "ethereum-sepolia"
  lastScannedBlock BigInt   @default(0)
  nextIndex        Int      @default(1) // HD address index; 0 is the hot wallet
  updatedAt        DateTime @updatedAt
}

model DepositAddress {
  id              String   @id @default(cuid())
  userId          String
  chain           String
  address         String
  derivationIndex Int
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chain])
  @@unique([chain, derivationIndex])
  @@index([address])
}

/// Successful sign-in events, powering the account's login history / device list.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum DepositStatus {
  PENDING // seen on-chain, awaiting confirmations
  CREDITED // confirmed and credited to the ledger
}

model Deposit {
  id            String        @id @default(cuid())
  userId        String
  chain         String
  symbol        String
  amount        Decimal       @db.Decimal(30, 10)
  address       String
  txHash        String
  blockNumber   BigInt
  confirmations Int           @default(0)
  status        DepositStatus @default(PENDING)
  creditedAt    DateTime?
  createdAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chain, txHash, symbol])
  @@index([userId, createdAt])
  @@index([status])
}

enum WithdrawalStatus {
  REQUESTED // funds locked, awaiting broadcast
  BROADCAST // signed & sent, awaiting confirmations
  CONFIRMED // on-chain confirmed, funds settled out
  FAILED // rejected/failed; funds returned to available
}

model Withdrawal {
  id        String           @id @default(cuid())
  userId    String
  chain     String
  symbol    String
  amount    Decimal          @db.Decimal(30, 10)
  fee       Decimal          @default(0) @db.Decimal(30, 10)
  toAddress String
  txHash    String?
  status    WithdrawalStatus @default(REQUESTED)
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}
